{
  "name": "ninja-skyblock-api",
  "version": "1.0.0",
  "description": "Backend API proxying and extending the Hypixel API for SkyBlock endpoints",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker:bazaar": "node dist/worker-bazaar.js",
    "start:worker:auctions": "node dist/worker-auctions.js",
    "start:worker:profiles": "node dist/worker-profiles.js",
    "dev:worker:bazaar": "tsx watch src/worker-bazaar.ts",
    "dev:worker:auctions": "tsx watch src/worker-auctions.ts",
    "dev:worker:profiles": "tsx watch src/worker-profiles.ts",
    "start:worker:resources": "node dist/worker-resources.js",
    "dev:worker:resources": "tsx watch src/worker-resources.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate": "node-pg-migrate",
    "migrate:up": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:create": "node-pg-migrate create"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.4.2",
    "bullmq": "^5.34.8",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.2",
    "node-pg-migrate": "^7.9.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "undici": "^7.24.6",
    "ws": "^8.18.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@types/ws": "^8.5.14",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^3.0.4",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
